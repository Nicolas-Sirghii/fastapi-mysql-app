# Redirect www → root
www.sirghiinicolai.com {
    redir https://sirghiinicolai.com{uri}
}

# Main site
sirghiinicolai.com {
    root * /usr/share/caddy
    file_server

    # Backend API: handle first
    handle_path /api/* {
        reverse_proxy backend:8000
    }

    # SPA fallback: everything else
    try_files {path} /index.html
}