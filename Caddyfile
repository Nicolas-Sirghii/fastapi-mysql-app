# Redirect www → root
www.sirghiinicolai.com {
    redir https://sirghiinicolai.com{uri}
}

# Main site (ONLY root domain here)
sirghiinicolai.com {
    root * /usr/share/caddy

    route {
        # API first
        handle_path /api/* {
            reverse_proxy backend:8000
        }

        # SPA fallback
        handle {
            try_files {path} /index.html
            file_server
        }
    }
}
