# Redirect www → root
www.sirghiinicolai.com {
    redir https://sirghiinicolai.com{uri}
}

# MAIN SITE
sirghiinicolai.com {
    root * /usr/share/caddy

    route {
        handle_path /api/* {
            reverse_proxy backend:8000
        }

        handle {
            try_files {path} /index.html
            file_server
        }
    }
}

# ADMIN SUBDOMAIN
admin33.sirghiinicolai.com {
    root * /usr/share/caddy-admin

    route {
        handle_path /api/* {
            reverse_proxy backend:8000
        }

        handle {
            try_files {path} /index.html
            file_server
        }
    }
}
